  "events": [
    {
      "id": "测字先生",
      "text": "路边测字先生托起罗盘:『客官,抽一字,卜一卦。』",
      "options": [
        {
          "label": "求字(得「炎」)",
          "gainChar": "炎"
        },
        {
          "label": "求财(墨锭 +40)",
          "ink": 40
        },
        {
          "label": "拱手离开"
        }
      ]
    },
    {
      "id": "墨池",
      "text": "一泓漆黑墨池泛着微光。传说浸墨可锻字,却伤元气。",
      "options": [
        {
          "label": "浸染字库(HP −6,得「焱」)",
          "hpDelta": -6,
          "gainChar": "焱"
        },
        {
          "label": "取墨而归(墨锭 +30)",
          "ink": 30
        },
        {
          "label": "绕道而行"
        }
      ]
    },
    {
      "id": "废稿堆",
      "text": "你撞见自己历次失败留下的废稿。废稿也是稿。",
      "options": [
        {
          "label": "翻找部件(得 木·木·火)",
          "gainComponents": [
            "木",
            "木",
            "火"
          ]
        },
        {
          "label": "静心重读(HP +8)",
          "hpDelta": 8
        },
        {
          "label": "转身离去"
        }
      ]
    },
    {
      "id": "书院",
      "text": "山间书院灯火未熄,先生愿留你半日。",
      "options": [
        {
          "label": "休整(HP +15)",
          "hpDelta": 15
        },
        {
          "label": "进修(得「灼」)",
          "gainChar": "灼"
        },
        {
          "label": "帮抄书换钱(墨锭 +20)",
          "ink": 20
        }
      ]
    },
    {
      "id": "字摊",
      "text": "路旁小摊,摊主捻须:『好字便宜卖,过时不候。』",
      "options": [
        {
          "label": "购「烧」(墨锭 40)",
          "inkCost": 40,
          "gainChar": "烧"
        },
        {
          "label": "购部件 火·土(墨锭 20)",
          "inkCost": 20,
          "gainComponents": [
            "火",
            "土"
          ]
        },
        {
          "label": "只看不买"
        }
      ]
    },
    {
      "id": "篝火",
      "text": "篝火正旺,暖意驱散了错字的阴气。",
      "options": [
        {
          "label": "休整(HP +20)",
          "hpDelta": 20
        },
        {
          "label": "烤字取暖(得部件 火)",
          "gainComponents": [
            "火"
          ]
        },
        {
          "label": "起身赶路"
        }
      ]
    },
    {
      "id": "赌书",
      "text": "书生摇扇:『赌一局飞花令?押注方可入席。』",
      "options": [
        {
          "label": "押注对赌(付 20 赢 50)",
          "inkCost": 20,
          "ink": 50
        },
        {
          "label": "观战学艺(HP +5)",
          "hpDelta": 5
        },
        {
          "label": "拱手不赌"
        }
      ]
    },
    {
      "id": "残碑",
      "text": "半截古碑上一个残字隐约生光,拓印恐伤元气。",
      "options": [
        {
          "label": "拓印残字(HP −8,得「壁」)",
          "hpDelta": -8,
          "gainChar": "壁"
        },
        {
          "label": "描摹碑文(得部件 土·土)",
          "gainComponents": [
            "土",
            "土"
          ]
        },
        {
          "label": "肃然离开"
        }
      ]
    }
